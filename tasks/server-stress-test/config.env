# Server memory stress test configuration
# Durations are kept in hours for easy editing.
# TIME_UNIT_SECONDS stays at 3600 in normal use. You can lower it only for script smoke tests.

TIME_UNIT_SECONDS=3600
BURN_HOURS=20
REST_HOURS=4
BURN_PHASES=3
CHUNK_HOURS=1

# Memory pressure target. The default is capped at 80% as requested.
MEMORY_PERCENT=80
VM_WORKERS=1
VM_METHOD=all
CPU_WORKERS=0

# Sampling and safety.
SAMPLE_SECONDS=5
MAX_TEMP_C=90

# Runtime folders. Relative paths are resolved from the script directory.
LOG_DIR=logs
STATE_DIR=state
REPORT_DIR=report
