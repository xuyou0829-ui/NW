# Server memory stress test configuration
# Durations are kept in hours for easy editing.
# TIME_UNIT_SECONDS stays at 3600 in normal use. You can lower it only for script smoke tests.

TIME_UNIT_SECONDS=3600
BURN_HOURS=20
REST_HOURS=4
BURN_PHASES=3
CHUNK_HOURS=1

# Memory pressure band. The controller tries to keep overall memory usage within this range.
MEMORY_MIN_PERCENT=75
MEMORY_TARGET_PERCENT=80
MEMORY_MAX_PERCENT=85
VM_WORKERS=8
CPU_WORKERS=0
CONTROL_WINDOW_SECONDS=300
MEMORY_RANGE_GRACE_SECONDS=900

# Sampling and safety.
SAMPLE_SECONDS=5
MAX_TEMP_C=90

# Runtime folders. Relative paths are resolved from the script directory.
LOG_DIR=logs
STATE_DIR=state
REPORT_DIR=report
